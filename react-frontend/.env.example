# Copy to .env for local development (never commit real secrets).

# Public API base URL for production builds (also set in CI via GitHub Actions secrets).
VITE_API_URL=

# Label shown in the UI (non-secret).
VITE_ENV=development

# Dev-only: Vite proxy target for /api (override if backend is not on localhost:4000).
VITE_PROXY_TARGET=http://localhost:4000
